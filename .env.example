# KamaClaude environment example
# Copy this file to .env, then uncomment exactly one LLM interface block below.

# -----------------------------------------------------------------------------
# Core daemon
# -----------------------------------------------------------------------------
KAMA_HOST=127.0.0.1
KAMA_PORT=7437

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
KAMA_LOG_LEVEL=INFO
# Leave empty to log only to stderr.
KAMA_LOG_FILE=~/.kama/logs/core.log
# text or json
KAMA_LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Optional config file override
# -----------------------------------------------------------------------------
# KAMA_CONFIG=~/.kama/config.toml

# -----------------------------------------------------------------------------
# Agent runtime
# -----------------------------------------------------------------------------
KAMA_MAX_STEPS=20

# -----------------------------------------------------------------------------
# LLM interface templates
# -----------------------------------------------------------------------------
# Rule: uncomment one block only.
# Required by code:
#   KAMA_LLM_PROVIDER=anthropic | openai
#   KAMA_LLM_DEFAULT_MODEL=<model name>
#   ANTHROPIC_API_KEY or OPENAI_API_KEY
# Optional compatible endpoints are shown in each block.

# --- Anthropic official API ---------------------------------------------------
# KAMA_LLM_PROVIDER=anthropic
# KAMA_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# --- Anthropic-compatible proxy ----------------------------------------------
# Use this when your endpoint speaks the Anthropic Messages API.
# KAMA_LLM_PROVIDER=anthropic
# KAMA_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...or-your-proxy-key
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint

# --- OpenAI official API ------------------------------------------------------
# KAMA_LLM_PROVIDER=openai
# KAMA_LLM_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- OpenAI-compatible proxy --------------------------------------------------
# Use this for providers compatible with OpenAI Chat Completions.
# Examples: DeepSeek/OpenRouter/one-api/litellm gateways, depending on your setup.
# KAMA_LLM_PROVIDER=openai
# KAMA_LLM_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...or-your-proxy-key
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# --- DeepSeek via OpenAI-compatible API --------------------------------------
# KAMA_LLM_PROVIDER=openai
# KAMA_LLM_DEFAULT_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- OpenRouter via OpenAI-compatible API ------------------------------------
# KAMA_LLM_PROVIDER=openai
# KAMA_LLM_DEFAULT_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Local OpenAI-compatible service -----------------------------------------
# For local gateways such as litellm, llama.cpp server, ollama-openai wrappers,
# or other services exposing /v1/chat/completions.
# KAMA_LLM_PROVIDER=openai
# KAMA_LLM_DEFAULT_MODEL=local-model-name
# OPENAI_API_KEY=not-needed-or-local-key
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# -----------------------------------------------------------------------------
# Trace and compaction knobs, normally leave commented
# -----------------------------------------------------------------------------
# KAMA_TRACE_ENABLED=true
# KAMA_TRACE_FILE=~/.kama/trace.jsonl
# KAMA_TRACE_INCLUDE_LLM_PAYLOAD=true
# KAMA_PERMISSION_TIMEOUT_S=60
# KAMA_COMPACT_THRESHOLD=0
# KAMA_COMPACT_TOOL_LIMIT=8000
# KAMA_COMPACT_TOOL_KEEP=4000
